{
  "name": "tiny-mcp-server",
  "version": "1.0.0",
  "description": "A simple MCP server with SQLite database",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "echo \"Error: MCP server should be started by the MCP Host, and not in a standalone manner\" && exit 1",
    "seed": "tsx src/scripts/seed.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
